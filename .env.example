# ── Gemini API Key ────────────────────────────────────────────────────────────
# Get your key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY='your-gemini-api-key-here'

# ── Model selection ───────────────────────────────────────────────────────────
# Options: gemini-2.0-flash-lite | gemini-2.0-flash | gemini-2.5-flash
GEMINI_MODEL='gemini-2.0-flash'

# ── MCP Data Sources ──────────────────────────────────────────────────────────
# Alpha Vantage: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE='your-alpha-vantage-key-here'

# Financial Datasets: https://financialdatasets.ai/
FINANCIAL_DATASET='your-financial-dataset-key-here'

# ── Redis (optional – falls back to in-memory if unavailable) ─────────────────
REDIS_URL='redis://localhost:6379'

# ── Flask ─────────────────────────────────────────────────────────────────────
FLASK_SECRET_KEY='change-me-in-production'
FLASK_DEBUG='false'
FLASK_PORT='5000'
